# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/foodstore

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# MercadoPago
MP_ACCESS_TOKEN=your-mp-access-token
MP_PUBLIC_KEY=your-mp-public-key
# For local webhook testing use ngrok: ngrok http 8000
# Then set MP_NOTIFICATION_URL=https://<your-ngrok-id>.ngrok.io/api/v1/pagos/webhook
MP_NOTIFICATION_URL=http://localhost:8000/api/v1/pagos/webhook
# Optional: set to verify MercadoPago webhook signatures in production
MP_WEBHOOK_SECRET=
